SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role JWT>

# Postgres direct connection for Drizzle migrations
# Supabase → Project Settings → Database → Connection string (URI mode)
# Supabase → Connect → Transaction pooler URI (port 6543, not the direct 5432 URI)
DATABASE_URL=postgresql://postgres.<ref>:<DB_PASSWORD>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<....apps.googleusercontent.com>
GOOGLE_CLIENT_SECRET=<GOCSPX-...>

# Better-Auth session signing secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<random 32-byte base64 string>

# Base URLs
SERVER_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:5173

# Shared secret for HMAC-signed scraper ↔ API requests
SCRAPER_HMAC_SECRET=<generate with: openssl rand -hex 32>

# HMAC key shared between server and Mac mini workers (any random 32+ char string)
WORKER_HMAC_KEY=

# Debounce window for inventory/meal-plan sync (ms). Default: 300000 (5 min)
SYNC_DEBOUNCE_MS=300000

# Anthropic API key — used for recipe URL/photo extraction and ingredient matching
# platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
