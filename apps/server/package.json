{
    "name": "@eat/server",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "db:generate": "drizzle-kit generate",
