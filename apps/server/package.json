    },
    "dependencies": {
        "@eat/openbrain": "workspace:*",
        "@eat/shared": "workspace:*",
        "@eat/taxonomy": "workspace:*",
        "@types/uuid": "^10.0.0",
        "better-auth": "^1.6.9",
        "cors": "^2.8.5",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "express": "^4.21.0",
        "postgres": "^3.4.9",
        "uuid": "^11.0.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/supertest": "^7.2.0",
        "drizzle-kit": "^0.31.10",
        "supertest": "^7.2.2",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.18"
