# The Vercel API base URL
API_BASE_URL=https://your-app.vercel.app

# Shared HMAC secret — must match SCRAPER_HMAC_SECRET on the server
SCRAPER_HMAC_SECRET=<generate with: openssl rand -hex 32>

# AES-256-GCM key for encrypted supermarket session blobs (32 bytes, base64)
SUPERMARKET_ENC_KEY=<generate with: openssl rand -base64 32>

# How often to poll for pending jobs (ms)
POLL_INTERVAL_MS=30000
