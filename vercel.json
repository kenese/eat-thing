{
  "buildCommand": "pnpm turbo build --filter=@eat/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "apps/server/src/app.ts": {
      "runtime": "@vercel/node@5",
      "includeFiles": "apps/server/src/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/apps/server/src/app.ts"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
